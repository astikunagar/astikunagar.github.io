# Warden local environment — Paavit static site (Jekyll)
# Setup:
#   1. Add to /etc/hosts:  127.0.0.1 local.paavit.com
#   2. warden svc up
#   3. warden sign-certificate local.paavit.com
#   4. warden env up
#   5. Open https://local.paavit.com

WARDEN_ENV_NAME=paavit
WARDEN_ENV_TYPE=local
WARDEN_WEB_ROOT=/

TRAEFIK_DOMAIN=local.paavit.com
TRAEFIK_SUBDOMAIN=

WARDEN_NGINX=1
WARDEN_DB=0
WARDEN_REDIS=0
WARDEN_RABBITMQ=0
WARDEN_ELASTICSEARCH=0
WARDEN_OPENSEARCH=0
WARDEN_VARNISH=0

NGINX_VERSION=1.24

WARDEN_ALLURE=0
WARDEN_SELENIUM=0
WARDEN_SELENIUM_DEBUG=0
WARDEN_BLACKFIRE=0

BLACKFIRE_CLIENT_ID=
BLACKFIRE_CLIENT_TOKEN=
BLACKFIRE_SERVER_ID=
BLACKFIRE_SERVER_TOKEN=
